{
  "name": "des-platform",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.15.0",
  "scripts": {
    "generate:schema": "pnpm --filter @des-platform/shared-schema schema:generate",
    "generate:catalog": "pnpm --filter @des-platform/shared-schema catalog:generate",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev:api": "pnpm --filter sim-api dev",
    "dev:viewer": "pnpm --filter viewer dev",
    "dev:shuttle-api": "pnpm --filter shuttle-api dev",
    "dev:shuttle-dashboard": "pnpm --filter shuttle-dashboard dev",
    "shuttle:prereq": "pnpm --filter shuttle-api prereq",
    "run:model": "pnpm --filter model-runner run run",
    "run:experiment": "pnpm --filter model-runner run experiment",
    "run:sweep": "pnpm --filter model-runner run sweep",
    "run:study": "pnpm --filter model-runner run study",
    "run:case": "pnpm run:study",
    "validate:model": "pnpm --filter model-runner run validate",
    "simulate:baseline": "pnpm --filter sim-api simulate:baseline",
    "report:baseline": "pnpm --filter reporting report:baseline",
    "report:model": "pnpm --filter reporting report:model",
    "mvp:generic": "pnpm run:study config/studies/fulfillment-center-mvp.study.json",
    "mvp:inline": "pnpm run:study config/studies/micro-fulfillment-inline.study.json",
    "test:shuttle": "vitest run packages/shuttle-sim-core/src/index.test.ts",
    "build": "pnpm run generate:schema && pnpm run generate:catalog && pnpm run typecheck && pnpm --filter viewer build"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
