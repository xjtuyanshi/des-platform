        },
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string",
          "default": ""
        },
        "modelPath": {
          "type": "string"
        },
        "outputDir": {
          "type": "string"
        },
        "validate": {
