{
  "schemaVersion": "des-platform.study.v1",
  "id": "micro-fulfillment-inline",
  "name": "Micro Fulfillment Inline Study",
  "description": "Self-contained one-file study with an embedded Process Flow and Material Handling model.",
  "outputDir": "output/studies/micro-fulfillment-inline",
  "validate": true,
  "failOnValidationError": true,
  "model": {
    "schemaVersion": "des-platform.v1",
    "id": "micro-fulfillment-inline",
    "name": "Micro Fulfillment Inline",
    "description": "Small warehouse flow with order arrivals, AMR travel, picking labor, and parameter sweep controls.",
    "parameters": [
      {
        "id": "order-mean-sec",
        "name": "Mean order interarrival time",
        "path": "/process/blocks/source/intervalSec/mean",
        "valueType": "number",
        "defaultValue": 60,
        "min": 30,
        "max": 120,
        "step": 5,
        "unit": "s"
      },
      {
        "id": "amr-speed-mps",
        "name": "AMR speed",
        "path": "/materialHandling/transporterFleets/amr/speedMps",
        "valueType": "number",
        "defaultValue": 1.3,
        "min": 0.8,
        "max": 2,
        "step": 0.1,
        "unit": "m/s"
      },
      {
        "id": "picker-count",
        "name": "Picking operators",
        "path": "/process/resourcePools/picker/capacity",
        "valueType": "integer",
        "defaultValue": 1,
        "min": 1,
        "max": 3,
        "step": 1,
        "unit": "operator"
      }
    ],
    "process": {
      "id": "micro-fulfillment-flow",
      "resourcePools": [
        {
          "id": "picker",
          "name": "Picking operators",
          "capacity": 1
        }
      ],
      "blocks": [
        {
          "id": "source",
          "kind": "source",
          "entityType": "order",
          "startAtSec": 0,
          "intervalSec": {
            "kind": "exponential",
            "mean": 60
          },
          "maxArrivals": 16,
          "attributes": {
            "channel": "ecommerce"
          }
        },
        {
          "id": "move-dock-to-rack",
          "kind": "moveByTransporter",
          "fleetId": "amr",
          "fromNodeId": "dock",
          "toNodeId": "rack",
          "loadTimeSec": 4,
          "unloadTimeSec": 3
        },
        {
          "id": "pick",
          "kind": "service",
          "resourcePoolId": "picker",
          "durationSec": {
            "kind": "triangular",
            "min": 25,
            "mode": 45,
            "max": 80
          },
          "queueCapacity": 12
        },
        {
          "id": "move-rack-to-pack",
          "kind": "moveByTransporter",
          "fleetId": "amr",
          "fromNodeId": "rack",
          "toNodeId": "pack",
          "loadTimeSec": 3,
          "unloadTimeSec": 3
        },
        {
          "id": "sink",
          "kind": "sink"
        }
      ],
      "connections": [
        {
          "from": "source",
          "to": "move-dock-to-rack"
        },
        {
          "from": "move-dock-to-rack",
          "to": "pick"
        },
        {
          "from": "pick",
          "to": "move-rack-to-pack"
        },
        {
          "from": "move-rack-to-pack",
          "to": "sink"
        }
      ]
    },
    "materialHandling": {
      "id": "micro-fulfillment-layout",
      "nodes": [
        {
          "id": "dock",
          "type": "dock",
          "x": 0,
          "z": 0
        },
        {
          "id": "rack",
          "type": "storage",
          "x": 14,
          "z": 0
        },
        {
          "id": "pack",
          "type": "station",
          "x": 14,
          "z": 9
        }
      ],
      "paths": [
        {
          "id": "dock-rack",
          "from": "dock",
          "to": "rack",
          "lengthM": 14,
          "speedLimitMps": 1.6,
          "capacity": 1
        },
        {
          "id": "rack-pack",
          "from": "rack",
          "to": "pack",
          "lengthM": 9,
          "speedLimitMps": 1.3,
          "capacity": 1
        }
      ],
      "transporterFleets": [
        {
          "id": "amr",
          "vehicleType": "amr",
          "navigation": "path-guided",
          "count": 1,
          "homeNodeId": "dock",
          "speedMps": 1.3,
          "accelerationMps2": 0.7,
          "decelerationMps2": 0.7,
          "lengthM": 1.1,
          "widthM": 0.8,
          "minClearanceM": 0.25
        }
      ],
      "obstacles": [
        {
          "id": "column-1",
          "x": 7,
          "z": 4,
          "widthM": 0.8,
          "depthM": 0.8,
          "heightM": 4
        }
      ]
    },
    "experiments": [
      {
        "id": "baseline",
        "name": "Baseline",
        "seed": 20260520,
        "replications": 4,
        "seedStride": 1,
        "parameterOverrides": {
          "order-mean-sec": 60,
          "amr-speed-mps": 1.3,
          "picker-count": 1
        },
        "stopTimeSec": 1800
      },
      {
        "id": "capacity-sweep",
        "name": "Capacity Sweep",
        "seed": 20260530,
        "replications": 3,
        "seedStride": 1,
        "sweep": {
          "order-mean-sec": [45, 60],
          "amr-speed-mps": [1, 1.5],
          "picker-count": [1, 2]
        },
        "stopTimeSec": 1800
      }
    ],
    "metadata": {
      "domain": "micro-fulfillment",
      "embeddedInStudy": true
    }
  },
  "runs": [
    {
      "experimentId": "baseline",
      "outputName": "baseline-run",
      "htmlReport": true
    }
  ],
  "replications": [
    {
      "experimentId": "baseline",
      "outputName": "baseline-experiment",
      "htmlReport": true
    }
  ],
  "sweeps": [
    {
      "experimentId": "capacity-sweep",
      "outputName": "capacity-sweep",
      "htmlReport": true
    }
  ],
  "metadata": {
    "domain": "micro-fulfillment",
    "selfContained": true
  }
}
