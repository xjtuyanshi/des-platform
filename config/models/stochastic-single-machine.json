{
  "schemaVersion": "des-platform.v1",
  "id": "stochastic-single-machine",
  "name": "Stochastic Single Machine",
  "description": "Generic DES model using seeded stochastic arrivals and triangular service times.",
  "parameters": [
    {
      "id": "arrival-mean-sec",
      "name": "Mean interarrival time",
      "path": "/process/blocks/source/intervalSec/mean",
      "valueType": "number",
      "defaultValue": 90,
      "min": 30,
      "max": 180,
      "step": 10,
      "unit": "s"
    },
    {
      "id": "service-mode-sec",
      "name": "Most likely service time",
      "path": "/process/blocks/service/durationSec/mode",
      "valueType": "number",
      "defaultValue": 100,
      "min": 60,
      "max": 160,
      "step": 5,
      "unit": "s"
    }
  ],
  "process": {
    "id": "stochastic-single-machine-flow",
    "resourcePools": [
      {
        "id": "machine",
        "capacity": 1
      }
    ],
    "blocks": [
      {
        "id": "source",
        "kind": "source",
        "entityType": "job",
        "startAtSec": 0,
        "intervalSec": {
          "kind": "exponential",
          "mean": 90
        },
        "maxArrivals": 20
      },
      {
        "id": "service",
        "kind": "service",
        "resourcePoolId": "machine",
        "durationSec": {
          "kind": "triangular",
          "min": 60,
          "mode": 100,
          "max": 180
        }
      },
      {
        "id": "sink",
        "kind": "sink"
      }
    ],
    "connections": [
      {
        "from": "source",
        "to": "service"
      },
      {
        "from": "service",
        "to": "sink"
      }
    ]
  },
  "experiments": [
    {
      "id": "seed-20260424",
      "seed": 20260424,
      "replications": 8,
      "seedStride": 1,
      "parameterOverrides": {
        "arrival-mean-sec": 90,
        "service-mode-sec": 100
      },
      "stopTimeSec": 3600
    },
    {
      "id": "seed-20260425",
      "seed": 20260425,
      "replications": 8,
      "seedStride": 1,
      "parameterOverrides": {
        "arrival-mean-sec": 75,
        "service-mode-sec": 120
      },
      "stopTimeSec": 3600
    },
    {
      "id": "arrival-service-sweep",
      "seed": 20260430,
      "replications": 4,
      "seedStride": 1,
      "sweep": {
        "arrival-mean-sec": [60, 90, 120],
        "service-mode-sec": [80, 120]
      },
      "stopTimeSec": 3600
    }
  ]
}
